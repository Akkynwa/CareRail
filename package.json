{
  "name": "carerail",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build --filter=...[origin/main]",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:push": "pnpm --filter @carerail/db prisma db push",
    "db:migrate": "pnpm --filter @carerail/db prisma migrate dev",
    "db:studio": "pnpm --filter @carerail/db prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.6.3"
  }
}