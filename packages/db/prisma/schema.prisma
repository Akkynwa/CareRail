generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Donor {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  password    String?
  createdAt   DateTime @default(now())

  donations   Donation[]
  transactions Transaction[]
}

model Beneficiary {
  id          String   @id @default(cuid())
  fullName    String
  bvn         String?  @unique
  nin         String?  @unique
  phone       String?  @unique
  password    String?
  createdAt   DateTime @default(now())

  wallet       Wallet?
  vouchers     Voucher[]
  transactions Transaction[]
}

model Vendor {
  id              String   @id @default(cuid())
  businessName    String
  merchantCode    String   @unique
  category        MerchantCategory @relation(fields: [categoryId], references: [id])
  categoryId      String
  contactPerson   String?
  phone           String?
  password        String?
  createdAt       DateTime @default(now())

  transactions Transaction[]
}

model MerchantCategory {
  id    String   @id @default(cuid())
  name  String   @unique
  vendors Vendor[]
}

model Wallet {
  id             String       @id @default(cuid())
  beneficiaryId  String       @unique
  balance        Int          @default(0)
  createdAt      DateTime     @default(now())

  beneficiary    Beneficiary  @relation(fields: [beneficiaryId], references: [id])
  vouchers       Voucher[]
}

model Voucher {
  id             String       @id @default(cuid())
  walletId       String
  beneficiaryId  String
  amount         Int
  purpose        String
  qrCodeValue    String       @unique
  isRedeemed     Boolean      @default(false)
  createdAt      DateTime     @default(now())
  expiresAt      DateTime?

  wallet         Wallet       @relation(fields: [walletId], references: [id])
  beneficiary    Beneficiary  @relation(fields: [beneficiaryId], references: [id])
  transactions   Transaction[]
}

model Transaction {
  id              String       @id @default(cuid())
  donorId         String?
  beneficiaryId   String?
  vendorId        String?
  voucherId       String?
  amount          Int
  type            String
  createdAt       DateTime     @default(now())

  donor           Donor?       @relation(fields: [donorId], references: [id])
  beneficiary     Beneficiary? @relation(fields: [beneficiaryId], references: [id])
  vendor          Vendor?      @relation(fields: [vendorId], references: [id])
  voucher         Voucher?     @relation(fields: [voucherId], references: [id])
}

model Donation {
  id          String   @id @default(cuid())
  donorId     String
  amount      Int
  purpose     String
  createdAt   DateTime @default(now())

  donor       Donor    @relation(fields: [donorId], references: [id])
}